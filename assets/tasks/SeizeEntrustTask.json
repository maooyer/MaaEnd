{
    "task": [
        {
            "name": "SeizeEntrustTask",
            "label": "$task.SeizeEntrustTask.label",
            "entry": "SeizeEntrustTaskMain",
            "description": "$task.SeizeEntrustTask.description",
            "option": [
                "SeizeEntrustTaskisSwipeMiddle",
                "SeizeEntrustTaskisGoDepotNodeWorld"
            ],
            "group": ["daily"]
        }
    ],
    "option": {
        "SeizeEntrustTaskisGoDepotNodeWorld": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisGoDepotNodeWorld.label",
            "description": "$task.SeizeEntrustTaskisGoDepotNodeWorld.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "option": [
                        "SeizeEntrustTaskisWalkingToDepotNode"
                    ],
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeEntrustTaskisWalkingToDepotNode": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisWalkingToDepotNode.label",
            "description": "$task.SeizeEntrustTaskisWalkingToDepotNode.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ],
            "controller": [
                "Win32-Front"
            ]
        },
        "SeizeEntrustTaskisSwipeMiddle": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisSwipeMiddle.label",
            "description": "$task.SeizeEntrustTaskisSwipeMiddle.description",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "SeizeEntrustTaskisSwipeALL"
                    ],
                    "pipeline_override": {
                        "SeizeEntrustTaskInDownSwipeUp": {
                            "enabled": true
                        },
                        "SeizeEntrustTaskInUpSwipeDown": {
                            "enabled": true
                        },
                        "SeizeEntrustTaskInDownSwipeMiddle": {
                            "enabled": true
                        },
                        "SeizeEntrustTaskSwipeDwon": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskInDownSwipeUp": {
                            "enabled": false
                        },
                        "SeizeEntrustTaskInUpSwipeDown": {
                            "enabled": false
                        },
                        "SeizeEntrustTaskInDownSwipeMiddle": {
                            "enabled": false
                        },
                        "SeizeEntrustTaskSwipeDwon": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeEntrustTaskisSwipeALL": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisSwipeALL.label",
            "description": "$task.SeizeEntrustTaskisSwipeALL.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskInUpSwipeDown": {
                            "enabled": true
                        },
                        "SeizeEntrustTaskInDownSwipeMiddle": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SeizeEntrustTaskInUpSwipeDown": {
                            "enabled": false
                        },
                        "SeizeEntrustTaskInDownSwipeMiddle": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
