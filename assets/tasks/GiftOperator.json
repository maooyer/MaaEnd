{
    "task": [
        {
            "name": "GiftOperator",
            "label": "$task.GiftOperator.label",
            "entry": "GiftOperatorMain",
            "description": "$task.GiftOperator.description",
            "option": [
                "GiftOperatorMoveMode"
            ],
            "controller": [
                "Win32-Front"
            ],
            "group": ["foreground"]
        }
    ],
    "option": {
        "GiftOperatorMoveMode": {
            "type": "select",
            "label": "$option.GiftOperatorMoveMode.label",
            "description": "$option.GiftOperatorMoveMode.description",
            "default_case": "Recorded",
            "cases": [
                {
                    "name": "Recorded",
                    "label": "$option.GiftOperatorMoveMode.cases.Recorded.label",
                    "pipeline_override": {
                        "GiftOperatorInDijiang0": {
                            "anchor": {
                                "GiftOperatorMoveModeAnchor": "GiftOperatorShiftToRunRecorded"
                            }
                        }
                    }
                },
                {
                    "name": "MapTracker",
                    "label": "$option.GiftOperatorMoveMode.cases.MapTracker.label",
                    "pipeline_override": {
                        "GiftOperatorInDijiang0": {
                            "anchor": {
                                "GiftOperatorMoveModeAnchor": "GiftOperatorShiftToRunMapTracker"
                            }
                        }
                    }
                }
            ]
        }
    }
}
