{
    "task": [
        {
            "name": "AutoEcoFarm",
            "label": "$task.AutoEcoFarm.label",
            "entry": "AutoEcoFarmMain",
            "description": "$task.AutoEcoFarm.description",
            "controller": [
                "Win32-Front"
            ],
            "option": [
                "FarmlandFindingScheme",
                "AutoEcoFarmClearBagBeforeTasks",
                "AutoEcoFarmClearBagAfterTasks"
            ],
            "group": ["foreground"]
        }
    ],
    "option": {
        "FarmlandFindingScheme": {
            "type": "select",
            "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.label",
            "default_case": "BRtoTL",
            "cases": [
                {
                    "name": "BRtoTL",
                    "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.cases[1].label",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmland": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "order_by": "Horizontal"
                                }
                            }
                        },
                        "_AutoEcoFarmFindEcoFarmAny": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagBeforeTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagBeforeTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagAfterTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagAfterTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enable": false
                        }
                    }
                }
            ]
        }
    }
}
